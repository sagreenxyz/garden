# Copy this file to .env and fill in the values for local development.
# In GitHub Actions, set these as Repository Secrets under Settings → Secrets → Actions.

# SITE_ACCESS_TOKEN is used to gate the private section of the site.
# It is injected at build time and a derived check value is embedded in the built HTML.
# Set any strong random string here. Example: openssl rand -hex 32
SITE_ACCESS_TOKEN=replace_with_a_strong_random_token
