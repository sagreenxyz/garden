# Copy this file to .env and fill in the values for local development.
# In GitHub Actions, set these as Repository Secrets under Settings → Secrets → Actions.

# AUTH_HASH gates the /private/ section behind a username/password login page.
# It must be the SHA-256 hex digest of the string "username:password".
#
# Generate your hash (replace myuser / mypassword with your chosen credentials):
#   Node.js:  node -e "const c=require('crypto');console.log(c.createHash('sha256').update('myuser:mypassword').digest('hex'))"
#   Shell:    echo -n 'myuser:mypassword' | sha256sum | awk '{print $1}'
#   PowerShell: $bytes = [System.Text.Encoding]::UTF8.GetBytes('myuser:mypassword')
#               $hash  = [System.Security.Cryptography.SHA256]::Create().ComputeHash($bytes)
#               [System.BitConverter]::ToString($hash).Replace('-','').ToLower()
#
# Leave blank (or omit the variable) to disable the login gate during local development.
AUTH_HASH=

# SITE_ACCESS_TOKEN is used to gate the private section of the site.
# It is injected at build time and a derived check value is embedded in the built HTML.
# Set any strong random string here. Example: openssl rand -hex 32
SITE_ACCESS_TOKEN=replace_with_a_strong_random_token
