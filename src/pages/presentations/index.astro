---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const entries = await getCollection('presentations', ({ data }) => !data.draft);
entries.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Presentations" description="Slide-based content">
  <h1>Presentations</h1>
  <p>Browse slide-based content and lectures.</p>

  {
    entries.length === 0 ? (
      <p>
        No presentations yet. Add Markdown files to <code>src/content/presentations/</code>.
      </p>
    ) : (
      <ul class="entry-list">
        {entries.map((entry) => (
          <li>
            <a href={`${base}presentations/${entry.slug}/`}>
              <strong>{entry.data.title}</strong>
            </a>
            {entry.data.slideCount && <span>({entry.data.slideCount} slides)</span>}
            {entry.data.description && <p>{entry.data.description}</p>}
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>
