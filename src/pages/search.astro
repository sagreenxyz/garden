---
import BaseLayout from '../layouts/BaseLayout.astro';
import '@pagefind/default-ui/css/ui.css';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Search" description="Search all content on this site.">
  <div class="max-w-3xl mx-auto py-10 px-4">
    <h1 class="text-3xl font-bold mb-6">Site Search</h1>
    <div id="search" data-bundle-path={`${base}pagefind/`}></div>
  </div>
</BaseLayout>

<script>
  import { PagefindUI } from '@pagefind/default-ui';

  const el = document.getElementById('search');
  const bundlePath = el?.dataset.bundlePath ?? `${import.meta.env.BASE_URL}pagefind/`;
  new PagefindUI({ element: '#search', bundlePath, showSubResults: true });
</script>
