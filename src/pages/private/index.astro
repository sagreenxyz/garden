---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Auth gates via client-side session check below.
const base = import.meta.env.BASE_URL;

// Count private/protected notes for the hub card (build-time safe — count only, no content exposed)
const privateNoteCount = (
  await getCollection(
    'notes',
    ({ data }) => !data.draft && (data.visibility === 'private' || data.visibility === 'protected')
  )
).length;
const reviewNeededCount = (
  await getCollection(
    'notes',
    ({ data }) =>
      !data.draft &&
      (data.visibility === 'private' || data.visibility === 'protected') &&
      data.needsReview
  )
).length;
---

<BaseLayout title="Private Area" description="Access restricted content">
  <div id="private-content" hidden>
    <h1 class="text-3xl font-bold mb-4">Private Area</h1>
    <p class="text-base-content/60 font-sans mb-6">
      You are authenticated. Below is a test note for verifying the login feature.
    </p>

    <article class="prose max-w-none mb-8">
      <div class="card card-border bg-base-100">
        <div class="card-body">
          <h2 class="card-title text-xl">🔒 Test Note: Login Feature Verification</h2>
          <time class="text-xs text-base-content/40" datetime="2026-03-25">March 25, 2026</time>
          <div class="flex flex-wrap gap-1 mt-1 mb-3">
            <span class="badge badge-outline badge-sm">private</span>
            <span class="badge badge-outline badge-sm">test</span>
            <span class="badge badge-outline badge-sm">auth</span>
          </div>
          <p class="font-sans text-base-content/80">
            If you can read this note, your login was successful. This page is protected by
            session-based authentication — access is only granted after supplying the correct
            credentials on the <strong>Sign In</strong> page.
          </p>
          <h3 class="font-semibold mt-4 mb-2 font-sans">What to verify</h3>
          <ul class="font-sans list-disc list-inside space-y-1 text-base-content/80">
            <li>
              Visiting <code>/private/</code> without logging in redirects you to <code
                >/login/</code
              >.
            </li>
            <li>After a successful sign-in you land back on this page and this note is visible.</li>
            <li>
              Clicking <strong>Sign Out</strong> clears your session and returns you to the login screen.
            </li>
            <li>
              Refreshing this page after signing out redirects you back to <code>/login/</code>.
            </li>
          </ul>
        </div>
      </div>
    </article>

    {/* Private Notes Hub card */}
    <div class="card card-border bg-base-100 mb-6">
      <div class="card-body">
        <h2 class="card-title text-lg font-sans">🗒️ Private Notes Hub</h2>
        <p class="font-sans text-base-content/70 text-sm mb-3">
          Browse and manage private and protected notes captured via GitHub Issues.
        </p>
        <div class="flex items-center gap-3 flex-wrap">
          <a href={`${base}private/notes/`} class="btn btn-primary btn-sm font-sans">
            View Private Notes ({privateNoteCount})
          </a>
          {
            reviewNeededCount > 0 && (
              <span class="badge badge-warning font-sans">
                {reviewNeededCount} need{reviewNeededCount === 1 ? 's' : ''} review
              </span>
            )
          }
        </div>
      </div>
    </div>

    <button id="logout-btn" class="btn btn-neutral btn-sm font-sans">Sign Out</button>
  </div>
</BaseLayout>

<script define:vars={{ base }}>
  const SESSION_KEY = 'lms_auth';
  const REDIRECT_KEY = 'lms_redirect';

  const privateContent = document.getElementById('private-content');
  const logoutBtn = document.getElementById('logout-btn');

  if (sessionStorage.getItem(SESSION_KEY) === 'ok') {
    if (privateContent) privateContent.hidden = false;
  } else {
    sessionStorage.setItem(
      REDIRECT_KEY,
      window.location.pathname + window.location.search + window.location.hash
    );
    window.location.replace(base + 'login/');
  }

  logoutBtn?.addEventListener('click', () => {
    sessionStorage.removeItem(SESSION_KEY);
    window.location.replace(base + 'login/');
  });
</script>
