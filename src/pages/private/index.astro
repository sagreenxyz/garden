---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Private Area" description="Access restricted content">
  <div
    style="background:#fff3cd;border:1px solid #ffc107;border-radius:0.5rem;padding:1rem;margin-bottom:1.5rem"
  >
    <strong>⚠️ Development Placeholder</strong><br />
    This private area has <em>no real authentication</em>. It is a UI scaffold only — any input
    bypasses the gate. Integrate a real auth provider (Supabase, Auth0, Clerk, etc.) before use.
  </div>

  <div id="auth-gate">
    <h1>Private Area</h1>
    <p>This section requires authentication. Replace this form with a real auth provider.</p>
    <form id="login-form">
      <label>
        Password (placeholder — not enforced)
        <input type="password" id="password-input" autocomplete="current-password" />
      </label>
      <button type="submit">Sign In (stub)</button>
    </form>
  </div>

  <div id="private-content" hidden>
    <h1>Private Area</h1>
    <p>Auth gate passed (stub only — replace with real auth). Private content will appear here.</p>
    <button id="logout-btn">Sign Out</button>
  </div>
</BaseLayout>

<script>
  // ⚠️  PLACEHOLDER ONLY — this provides NO real security.
  // Any non-empty input bypasses this gate.
  // Replace with a proper auth provider (Supabase, Auth0, Clerk, etc.) before production use.
  const PRIVATE_PASS_KEY = 'lms_private_auth';

  const loginForm = document.getElementById('login-form') as HTMLFormElement | null;
  const authGate = document.getElementById('auth-gate');
  const privateContent = document.getElementById('private-content');
  const logoutBtn = document.getElementById('logout-btn');

  function checkAuth() {
    return sessionStorage.getItem(PRIVATE_PASS_KEY) === 'stub_authenticated';
  }

  function showContent() {
    if (authGate) authGate.hidden = true;
    if (privateContent) privateContent.hidden = false;
  }

  function showGate() {
    if (authGate) authGate.hidden = false;
    if (privateContent) privateContent.hidden = true;
  }

  if (checkAuth()) {
    showContent();
  }

  loginForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    // TODO: Replace this entire block with a call to your auth provider SDK.
    sessionStorage.setItem(PRIVATE_PASS_KEY, 'stub_authenticated');
    showContent();
  });

  logoutBtn?.addEventListener('click', () => {
    sessionStorage.removeItem(PRIVATE_PASS_KEY);
    showGate();
  });
</script>
