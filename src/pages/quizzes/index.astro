---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const entries = await getCollection('quizzes', ({ data }) => !data.draft);

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Quizzes" description="Assessments to test your knowledge">
  <h1 class="text-3xl font-bold mb-2">Quizzes &amp; Exams</h1>
  <p class="text-base-content/60 font-sans mb-6">Test your knowledge with these assessments.</p>

  {
    entries.length === 0 ? (
      <div class="alert font-sans">
        <span>
          No quizzes yet. Add JSON files to <code>src/content/quizzes/</code>.
        </span>
      </div>
    ) : (
      <ul class="space-y-4">
        {entries.map((entry) => (
          <li>
            <a
              href={`${base}quizzes/${entry.id}/`}
              class="card card-border bg-base-100 hover:shadow-md transition-shadow no-underline font-sans block"
            >
              <div class="card-body py-4">
                <h2 class="card-title text-base">{entry.data.title}</h2>
                {entry.data.description && (
                  <p class="text-sm text-base-content/60 mt-1">{entry.data.description}</p>
                )}
                <div class="flex gap-3 mt-2 text-xs text-base-content/50">
                  <span>{entry.data.questions.length} questions</span>
                  <span>Passing: {entry.data.passingScore}%</span>
                  {entry.data.timeLimit && <span>{entry.data.timeLimit} min</span>}
                </div>
              </div>
            </a>
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>
