---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const entries = await getCollection('quizzes', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
};

const { entry } = Astro.props;
const quiz = entry.data;
const quizId = entry.id;
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={quiz.title} description={quiz.description}>
  <div class="max-w-2xl mx-auto">
    <!-- Quiz Header -->
    <div class="mb-8">
      <a
        href={`${base}quizzes/`}
        class="inline-flex items-center gap-1 text-sm text-base-content/50 hover:text-primary transition-colors font-sans mb-3"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
        </svg>
        All Quizzes
      </a>
      <h1 class="text-3xl font-bold mb-2 text-base-content">{quiz.title}</h1>
      {quiz.description && <p class="text-base-content/60 font-sans mb-4 leading-relaxed">{quiz.description}</p>}
      <div class="flex flex-wrap gap-3 font-sans">
        <span class="badge badge-neutral badge-lg gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"/>
            <path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd"/>
          </svg>
          {quiz.questions.length} questions
        </span>
        <span class="badge badge-neutral badge-lg gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          Pass: {quiz.passingScore}%
        </span>
        {quiz.timeLimit && (
          <span class="badge badge-neutral badge-lg gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
            </svg>
            {quiz.timeLimit} min
          </span>
        )}
      </div>
    </div>

    <!-- Progress bar -->
    <div id="quiz-progress-wrap" class="mb-6 font-sans">
      <div class="flex justify-between text-xs text-base-content/50 mb-1">
        <span id="progress-label">Question <span id="progress-current">0</span> of {quiz.questions.length} answered</span>
        <span id="progress-pct">0%</span>
      </div>
      <div class="w-full bg-base-300 rounded-full h-2">
        <div id="progress-bar" class="bg-primary h-2 rounded-full transition-all duration-300" style="width:0%"></div>
      </div>
    </div>

    <form id="quiz-form" class="space-y-5 font-sans">
      {
        quiz.questions.map((q, i) => (
          <div class="card bg-base-100 shadow-sm border border-base-200 rounded-2xl overflow-hidden" data-question-card>
            <div class="px-5 pt-5 pb-3 border-b border-base-200 bg-base-200/40">
              <div class="flex items-start gap-3">
                <span class="flex-shrink-0 inline-flex items-center justify-center w-7 h-7 rounded-full bg-primary text-primary-content text-xs font-bold mt-0.5">
                  {i + 1}
                </span>
                <p class="font-semibold text-base text-base-content leading-snug">{q.text}</p>
              </div>
            </div>

            <div class="px-5 py-4 space-y-2.5">
              {q.type === 'multiple-choice' &&
                q.options?.map((opt, oi) => {
                  const letter = ['A', 'B', 'C', 'D', 'E', 'F'][oi] ?? String(oi + 1);
                  return (
                    <label class="quiz-option flex items-center gap-3 p-3 rounded-xl border border-base-200 cursor-pointer hover:border-primary hover:bg-primary/5 transition-all duration-150 select-none">
                      <input type="radio" name={q.id} value={opt} required class="sr-only" />
                      <span class="flex-shrink-0 inline-flex items-center justify-center w-6 h-6 rounded-full border-2 border-base-300 text-xs font-bold text-base-content/60 option-letter transition-all duration-150">
                        {letter}
                      </span>
                      <span class="text-sm leading-snug">{opt}</span>
                    </label>
                  );
                })}

              {q.type === 'true-false' && (
                <>
                  <label class="quiz-option flex items-center gap-3 p-3 rounded-xl border border-base-200 cursor-pointer hover:border-primary hover:bg-primary/5 transition-all duration-150 select-none">
                    <input type="radio" name={q.id} value="True" required class="sr-only" />
                    <span class="flex-shrink-0 inline-flex items-center justify-center w-6 h-6 rounded-full border-2 border-base-300 text-xs font-bold text-base-content/60 option-letter transition-all duration-150">
                      T
                    </span>
                    <span class="text-sm font-medium">True</span>
                  </label>
                  <label class="quiz-option flex items-center gap-3 p-3 rounded-xl border border-base-200 cursor-pointer hover:border-primary hover:bg-primary/5 transition-all duration-150 select-none">
                    <input type="radio" name={q.id} value="False" required class="sr-only" />
                    <span class="flex-shrink-0 inline-flex items-center justify-center w-6 h-6 rounded-full border-2 border-base-300 text-xs font-bold text-base-content/60 option-letter transition-all duration-150">
                      F
                    </span>
                    <span class="text-sm font-medium">False</span>
                  </label>
                </>
              )}

              {q.type === 'short-answer' && (
                <input
                  type="text"
                  name={q.id}
                  placeholder="Type your answer here…"
                  required
                  class="input input-bordered w-full rounded-xl text-sm"
                />
              )}
            </div>
          </div>
        ))
      }

      <div class="flex items-center justify-between pt-2">
        <p id="unanswered-warning" class="text-sm text-error font-sans hidden">
          Please answer all questions before submitting.
        </p>
        <div class="ml-auto">
          <button type="submit" class="btn btn-primary btn-lg gap-2 rounded-xl font-sans">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            Submit Quiz
          </button>
        </div>
      </div>
    </form>

    <!-- Result panel -->
    <div id="quiz-result" hidden class="mt-4 space-y-6 font-sans">
      <!-- Score banner -->
      <div id="quiz-alert" class="rounded-2xl p-6 text-center">
        <div id="result-icon" class="text-5xl mb-3"></div>
        <p id="quiz-score" class="text-2xl font-bold mb-1"></p>
        <p id="quiz-score-sub" class="text-sm opacity-80"></p>
      </div>

      <!-- Per-question review -->
      <div>
        <h2 class="text-lg font-bold mb-3 text-base-content">Review Your Answers</h2>
        <div id="review-list" class="space-y-4"></div>
      </div>

      <!-- Retry / back buttons -->
      <div class="flex gap-3 pt-2">
        <button id="retry-btn" class="btn btn-primary btn-outline rounded-xl gap-2 font-sans">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M4 2a1 1 0 011 1v2.101a7.002 7.002 0 0111.601 2.566 1 1 0 11-1.861.726A5.001 5.001 0 005.999 7H9a1 1 0 010 2H4a1 1 0 01-1-1V3a1 1 0 011-1zm.008 9.057a1 1 0 011.276.61A5.002 5.002 0 0014.001 13H11a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0v-2.101a7.002 7.002 0 01-11.601-2.566 1 1 0 01.61-1.276z" clip-rule="evenodd"/>
          </svg>
          Try Again
        </button>
        <a href={`${base}quizzes/`} class="btn btn-ghost rounded-xl gap-2 font-sans">
          ← All Quizzes
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  /* Selected option state */
  .quiz-option:has(input:checked) {
    border-color: var(--color-primary);
    background-color: color-mix(in oklch, var(--color-primary) 8%, transparent);
  }
  .quiz-option:has(input:checked) .option-letter {
    border-color: var(--color-primary);
    background-color: var(--color-primary);
    color: var(--color-primary-content);
  }
  /* Correct answer highlight (post-submit) */
  .quiz-option.is-correct {
    border-color: var(--color-success, #22c55e);
    background-color: color-mix(in oklch, var(--color-success, #22c55e) 10%, transparent);
  }
  .quiz-option.is-correct .option-letter {
    border-color: var(--color-success, #22c55e);
    background-color: var(--color-success, #22c55e);
    color: #fff;
  }
  /* Wrong answer highlight (post-submit) */
  .quiz-option.is-wrong {
    border-color: var(--color-error, #ef4444);
    background-color: color-mix(in oklch, var(--color-error, #ef4444) 10%, transparent);
  }
  .quiz-option.is-wrong .option-letter {
    border-color: var(--color-error, #ef4444);
    background-color: var(--color-error, #ef4444);
    color: #fff;
  }
</style>

<script define:vars={{ quiz, quizId, base }}>
  const form = document.getElementById('quiz-form');
  const resultDiv = document.getElementById('quiz-result');
  const alertEl = document.getElementById('quiz-alert');
  const scoreP = document.getElementById('quiz-score');
  const scoreSub = document.getElementById('quiz-score-sub');
  const resultIcon = document.getElementById('result-icon');
  const reviewList = document.getElementById('review-list');
  const retryBtn = document.getElementById('retry-btn');
  const progressBar = document.getElementById('progress-bar');
  const progressCurrent = document.getElementById('progress-current');
  const progressPct = document.getElementById('progress-pct');
  const unansweredWarning = document.getElementById('unanswered-warning');

  const total = quiz.questions.length;

  // ── Progress tracking ────────────────────────────────────────────────────
  function updateProgress() {
    const answered = new Set(
      [...document.querySelectorAll('input[type="radio"]:checked')].map((el) => el.name)
    ).size;
    const pct = Math.round((answered / total) * 100);
    if (progressBar) progressBar.style.width = pct + '%';
    if (progressCurrent) progressCurrent.textContent = String(answered);
    if (progressPct) progressPct.textContent = pct + '%';
  }

  // Highlight selected option visually via JS (supplement the CSS :has() for older browsers)
  function highlightSelection(radio) {
    const groupName = radio.name;
    document.querySelectorAll(`input[name="${groupName}"]`).forEach((r) => {
      r.closest('label')?.classList.remove('!border-primary', '!bg-primary/10');
    });
    radio.closest('label')?.classList.add('!border-primary', '!bg-primary/10');
  }

  form?.addEventListener('change', (e) => {
    if (e.target?.type === 'radio') highlightSelection(e.target);
    updateProgress();
  });

  // ── Submission ────────────────────────────────────────────────────────────
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const formData = new FormData(form);

    // Check all answered
    const unanswered = quiz.questions.filter((q) => q.type !== 'short-answer' && !formData.get(q.id));
    if (unanswered.length) {
      if (unansweredWarning) unansweredWarning.classList.remove('hidden');
      // Scroll to first unanswered
      const firstId = unanswered[0].id;
      document.querySelector(`[name="${firstId}"]`)?.closest('[data-question-card]')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }
    if (unansweredWarning) unansweredWarning.classList.add('hidden');

    let correct = 0;
    const results = quiz.questions.map((q) => {
      const userAnswer = (formData.get(q.id) ?? '').toString().trim().toLowerCase();
      const expected = Array.isArray(q.answer)
        ? q.answer.map((a) => a.toLowerCase())
        : [q.answer.toLowerCase()];
      const isCorrect = expected.includes(userAnswer);
      if (isCorrect) correct++;
      return { q, userAnswer, expected, isCorrect };
    });

    const pct = Math.round((correct / total) * 100);
    const passed = pct >= quiz.passingScore;

    // ── Score banner ─────────────────────────────────────────────────────
    if (resultIcon) resultIcon.textContent = passed ? '🎉' : '📝';
    if (scoreP) scoreP.textContent = `${pct}% — ${passed ? 'Passed!' : 'Not yet passed'}`;
    if (scoreSub) {
      scoreSub.textContent = `You answered ${correct} of ${total} correctly. Passing score: ${quiz.passingScore}%`;
    }
    if (alertEl) {
      alertEl.style.cssText = passed
        ? 'background-color:color-mix(in oklch,var(--color-success,#22c55e) 12%,transparent);border:1px solid color-mix(in oklch,var(--color-success,#22c55e) 30%,transparent);'
        : 'background-color:color-mix(in oklch,var(--color-error,#ef4444) 12%,transparent);border:1px solid color-mix(in oklch,var(--color-error,#ef4444) 30%,transparent);';
    }

    // ── Per-question review ───────────────────────────────────────────────
    if (reviewList) {
      reviewList.innerHTML = '';
      results.forEach(({ q, userAnswer, expected, isCorrect }, idx) => {
        const wrap = document.createElement('div');
        wrap.style.cssText = isCorrect
          ? 'border:1px solid color-mix(in oklch,var(--color-success,#22c55e) 40%,transparent);background-color:color-mix(in oklch,var(--color-success,#22c55e) 5%,transparent);border-radius:0.75rem;padding:1rem;'
          : 'border:1px solid color-mix(in oklch,var(--color-error,#ef4444) 40%,transparent);background-color:color-mix(in oklch,var(--color-error,#ef4444) 5%,transparent);border-radius:0.75rem;padding:1rem;';

        const header = document.createElement('div');
        header.className = 'flex items-start gap-2 mb-2';

        const icon = document.createElement('span');
        icon.textContent = isCorrect ? '✅' : '❌';
        icon.className = 'text-base flex-shrink-0 mt-0.5';

        const qText = document.createElement('p');
        qText.className = 'text-sm font-semibold text-base-content leading-snug';
        qText.textContent = `${idx + 1}. ${q.text}`;

        header.appendChild(icon);
        header.appendChild(qText);
        wrap.appendChild(header);

        const detail = document.createElement('div');
        detail.className = 'ml-6 space-y-1 text-xs font-sans';

        const yourAns = document.createElement('p');
        yourAns.style.color = isCorrect ? 'var(--color-success,#22c55e)' : 'var(--color-error,#ef4444)';
        yourAns.textContent = `Your answer: ${userAnswer || '(no answer)'}`;
        detail.appendChild(yourAns);

        if (!isCorrect) {
          const correctAns = document.createElement('p');
          correctAns.style.color = 'var(--color-success,#22c55e)';
          correctAns.textContent = `Correct answer: ${expected.join(' / ')}`;
          detail.appendChild(correctAns);
        }

        if (q.explanation) {
          const rat = document.createElement('p');
          rat.className = 'text-base-content/60 mt-2 leading-snug';
          rat.textContent = `💡 ${q.explanation}`;
          detail.appendChild(rat);
        }

        wrap.appendChild(detail);
        reviewList.appendChild(wrap);
      });
    }

    if (resultDiv) resultDiv.hidden = false;
    if (form) form.hidden = true;

    resultDiv?.scrollIntoView({ behavior: 'smooth', block: 'start' });

    // ── Persist to localStorage ───────────────────────────────────────────
    if (typeof localStorage !== 'undefined') {
      const STORAGE_KEY = 'lms_quiz_history';
      let history = [];
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (raw) history = JSON.parse(raw);
      } catch {}
      history.push({
        quizId,
        title: quiz.title,
        score: pct,
        passed,
        date: new Date().toISOString(),
      });
      localStorage.setItem(STORAGE_KEY, JSON.stringify(history));
    }
  });

  // ── Retry ─────────────────────────────────────────────────────────────────
  retryBtn?.addEventListener('click', () => {
    form?.reset();
    // Clear visual selections
    document.querySelectorAll('.quiz-option').forEach((el) => {
      el.classList.remove('!border-primary', '!bg-primary/10');
    });
    if (form) form.hidden = false;
    if (resultDiv) resultDiv.hidden = true;
    if (progressBar) progressBar.style.width = '0%';
    if (progressCurrent) progressCurrent.textContent = '0';
    if (progressPct) progressPct.textContent = '0%';
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
