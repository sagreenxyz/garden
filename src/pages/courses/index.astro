---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getReadingTime } from '../../utils/readingTime';

const entries = await getCollection('courses', ({ data }) => !data.draft);
entries.sort((a, b) => a.data.order - b.data.order);

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Courses" description="Structured learning paths with ordered lessons">
  <h1 class="text-3xl font-bold mb-2">Courses</h1>
  <p class="text-base-content/60 font-sans mb-6">
    Structured learning paths to guide your education.
  </p>

  {
    entries.length === 0 ? (
      <div class="alert font-sans">
        <span>
          No courses yet. Add <code>.mdx</code> files to <code>src/content/courses/</code>.
        </span>
      </div>
    ) : (
      <ul class="space-y-4">
        {entries.map((entry) => (
          <li>
            <a
              href={`${base}courses/${entry.slug}/`}
              class="card card-border bg-base-100 hover:shadow-md transition-shadow no-underline font-sans block"
            >
              <div class="card-body py-4">
                <h2 class="card-title text-base">
                  {entry.data.title}
                  <span class="badge badge-primary badge-sm capitalize ml-2">
                    {entry.data.level}
                  </span>
                </h2>
                <p class="text-sm text-base-content/60 mt-1">{entry.data.description}</p>
                <div class="flex flex-wrap items-center gap-2 mt-2 text-xs text-base-content/50 font-sans">
                  <span class="inline-flex items-center gap-1">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="11"
                      height="11"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <circle cx="12" cy="12" r="10" />
                      <polyline points="12 6 12 12 16 14" />
                    </svg>
                    {getReadingTime(entry.body)} min read
                  </span>
                  {entry.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-1">
                      {entry.data.tags.map((tag) => (
                        <span class="badge badge-outline badge-sm">{tag}</span>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            </a>
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>
