---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import ContentLayout from '../../layouts/ContentLayout.astro';
import { getRelatedContent } from '../../utils/related';
import type { RelatedItem } from '../../utils/related';
import { getReadingTime } from '../../utils/readingTime';

export const getStaticPaths: GetStaticPaths = async () => {
  const base = import.meta.env.BASE_URL;
  const [entries, allEncyclopedia, allNotes] = await Promise.all([
    getCollection('courses', ({ data }) => !data.draft),
    getCollection('encyclopedia', ({ data }) => !data.draft),
    getCollection(
      'notes',
      ({ data }) => !data.draft && data.visibility === 'public' && data.reviewState === 'published'
    ),
  ]);

  return entries.map((entry) => {
    const currentTags = entry.data.tags ?? [];
    return {
      params: { slug: entry.slug },
      props: {
        entry,
        relatedEncyclopedia: getRelatedContent(
          entry.slug,
          currentTags,
          allEncyclopedia,
          (slug) => `${base}encyclopedia/${slug}/`
        ),
        relatedCourses: getRelatedContent(
          entry.slug,
          currentTags,
          entries,
          (slug) => `${base}courses/${slug}/`
        ),
        relatedNotes: getRelatedContent(
          entry.slug,
          currentTags,
          allNotes,
          (slug) => `${base}notes/${slug}/`
        ),
      },
    };
  });
};

const {
  entry,
  relatedEncyclopedia,
  relatedCourses,
  relatedNotes,
}: {
  entry: Awaited<ReturnType<typeof getCollection<'courses'>>>[number];
  relatedEncyclopedia: RelatedItem[];
  relatedCourses: RelatedItem[];
  relatedNotes: RelatedItem[];
} = Astro.props;
const { Content } = await entry.render();
const readingTime = getReadingTime(entry.body);
---

<ContentLayout
  title={entry.data.title}
  description={entry.data.description}
  publishedAt={entry.data.publishedAt}
  tags={entry.data.tags}
  curriculum={entry.data.curriculum}
  collection="courses"
  level={entry.data.level}
  readingTime={readingTime}
  relatedEncyclopedia={relatedEncyclopedia}
  relatedCourses={relatedCourses}
  relatedNotes={relatedNotes}
>
  <Content />
</ContentLayout>
