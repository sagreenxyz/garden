---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Flashcard from '../../components/lms/Flashcard.svelte';
import glossary from '../../data/glossary.json';
import type { GlossaryEntry } from '../../types/glossary';

const base = import.meta.env.BASE_URL;
const terms = glossary as GlossaryEntry[];
---

<BaseLayout
  title="Glossary Flashcards"
  description="Study glossary terms with interactive flashcards"
>
  <div class="mb-6 flex items-center justify-between">
    <h1 class="text-3xl font-bold">Flashcards</h1>
    <a href={`${base}glossary/`} class="btn btn-ghost btn-sm font-sans gap-2">
      ← Back to Glossary
    </a>
  </div>
  <p class="text-base-content/60 font-sans mb-8">
    Click a card to flip it and reveal the definition. Use the buttons to navigate or shuffle the
    deck.
  </p>

  <Flashcard terms={terms} client:load />
</BaseLayout>
