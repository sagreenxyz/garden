---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;

// Fetch the 3 most-recent changelog entries for the What's New section
const allChangelog = await getCollection('changelog', ({ data }) => !data.draft);
allChangelog.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
const recentChangelog = allChangelog.slice(0, 3);

const contentTypeBadge: Record<string, string> = {
  encyclopedia: 'badge-info',
  course: 'badge-success',
  note: 'badge-warning',
  quiz: 'badge-error',
  presentation: 'badge-secondary',
  other: 'badge-neutral',
};

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}

const features = [
  {
    icon: '🛡️',
    title: 'Secure by Design',
    description:
      'Credentials are hashed client-side with SHA-256. No server required.',
    href: null,
  },
  {
    icon: '🔒',
    title: 'Protected Content',
    description: 'All content is available to authenticated users — sign in to access courses, notes, quizzes, and more.',
    href: `${base}login/`,
  },
];

const sections = [
  {
    title: 'Encyclopedia',
    href: `${base}encyclopedia/`,
    description: 'Authoritative reference articles on specific topics',
    icon: '📖',
  },
  {
    title: 'Courses',
    href: `${base}courses/`,
    description: 'Structured learning paths with ordered lessons',
    icon: '🎓',
  },
  {
    title: 'Notes',
    href: `${base}notes/`,
    description: 'Quick references and personal notes',
    icon: '📝',
  },
  {
    title: 'Presentations',
    href: `${base}presentations/`,
    description: 'Web-based slide presentations',
    icon: '📊',
  },
  {
    title: 'Quizzes',
    href: `${base}quizzes/`,
    description: 'Assessments to test your knowledge',
    icon: '✅',
  },
  {
    title: 'Glossary',
    href: `${base}glossary/`,
    description: 'Keyword and keyphrase definitions',
    icon: '🔑',
  },
  {
    title: 'Infection Control Challenge',
    href: `${base}infection-control/`,
    description: 'Gamified isolation precautions simulator — 5 clinical cases',
    icon: '🦠',
  },
  {
    title: 'NGN Bowtie Questions',
    href: `${base}bowtie/`,
    description: 'Practice NCLEX Next Generation bowtie clinical judgment questions',
    icon: '🎯',
  },
];
---

<BaseLayout
  title="Home"
  description="Garden — a digital garden for nursing school, with courses, notes, encyclopedias, quizzes, and more."
>
  <!-- Hero -->
  <section class="text-center py-16 px-4">
    <!-- Leaf icon -->
    <div class="flex justify-center mb-6">
      <svg
        width="56"
        height="56"
        viewBox="0 0 24 24"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <defs>
          <linearGradient
            id="hero-leaf"
            x1="4"
            y1="2"
            x2="20"
            y2="22"
            gradientUnits="userSpaceOnUse"
          >
            <stop offset="0%" stop-color="#22c55e"></stop>
            <stop offset="100%" stop-color="#16a34a"></stop>
          </linearGradient>
        </defs>
        <path
          d="M17 8C8 10 5.9 16.17 3.82 21.34L5.71 22l1-2.3A4.49 4.49 0 008 20C19 20 22 3 22 3c-1 2-8 7-13 7"
          fill="url(#hero-leaf)"></path>
      </svg>
    </div>

    <h1 class="text-5xl font-extrabold tracking-tight mb-5" style="color:#1a1a2e;">
      Welcome to Garden
    </h1>

    <p class="text-lg text-base-content/70 max-w-2xl mx-auto mb-3 leading-relaxed">
      A digital garden for nursing school — courses, encyclopedias, notes, presentations, quizzes,
      and more — cultivated for BSN learners.
    </p>

    <p class="text-sm text-base-content/40 mb-10">
      100% static, hosted on GitHub Pages. No backend. No passwords transmitted.
    </p>

    <!-- CTA buttons -->
    <div class="flex flex-wrap justify-center gap-4">
      <a
        href={`${base}encyclopedia/`}
        class="inline-flex items-center gap-2 px-7 py-3 rounded-xl bg-indigo-600 text-white font-semibold text-base hover:bg-indigo-700 transition-colors shadow-md"
      >
        Browse Content
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>

  <!-- Feature cards -->
  <section class="grid grid-cols-1 sm:grid-cols-2 gap-5 mt-4 px-4 pb-16 max-w-2xl mx-auto w-full">
    {
      features.map((f) => (
        <div class="feature-card bg-white rounded-2xl p-6 border border-base-300">
          <div class="text-3xl mb-4">{f.icon}</div>
          <h2 class="text-base font-bold mb-2" style="color:#1a1a2e;">
            {f.title}
          </h2>
          <p class="text-sm text-base-content/60 leading-relaxed">{f.description}</p>
        </div>
      ))
    }
  </section>

  <!-- What's New section -->
  {
    recentChangelog.length > 0 && (
      <section class="px-4 pb-10">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-xl font-bold" style="color:#1a1a2e;">
            What's New
          </h2>
          <a href={`${base}changelog/`} class="text-sm text-indigo-600 hover:underline font-medium">
            View all →
          </a>
        </div>
        <ul class="space-y-3">
          {recentChangelog.map((entry) => (
            <li>
              <div class="card bg-white border border-base-300 hover:shadow-md transition-shadow rounded-xl">
                <div class="card-body py-3 px-5">
                  <div class="flex flex-wrap items-center gap-2 mb-1">
                    <span
                      class={`badge badge-sm ${contentTypeBadge[entry.data.contentType] ?? 'badge-neutral'}`}
                    >
                      {entry.data.contentType}
                    </span>
                    <time
                      datetime={entry.data.publishedAt.toISOString()}
                      class="text-xs text-base-content/50"
                    >
                      {formatDate(entry.data.publishedAt)}
                    </time>
                  </div>
                  <h3 class="font-semibold text-sm" style="color:#1a1a2e;">
                    {entry.data.relatedUrl ? (
                      <a href={entry.data.relatedUrl} class="hover:underline">
                        {entry.data.title}
                      </a>
                    ) : (
                      entry.data.title
                    )}
                  </h3>
                  <p class="text-xs text-base-content/60 mt-0.5 line-clamp-2">
                    {entry.data.summary}
                  </p>
                </div>
              </div>
            </li>
          ))}
        </ul>
      </section>
    )
  }

  <!-- Content sections grid -->
  <section class="px-4 pb-16">
    <h2 class="text-xl font-bold mb-5" style="color:#1a1a2e;">Explore Content</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {
        sections.map((section) => (
          <a
            href={section.href}
            class="feature-card card bg-white border border-base-300 hover:shadow-md transition-shadow no-underline rounded-xl"
          >
            <div class="card-body py-5 px-5">
              <span class="text-2xl">{section.icon}</span>
              <h3 class="card-title text-sm font-semibold mt-2" style="color:#1a1a2e;">
                {section.title}
              </h3>
              <p class="text-xs text-base-content/60">{section.description}</p>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
