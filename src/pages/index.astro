---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;

const features = [
  {
    icon: '🌐',
    title: 'Public Side',
    description: 'Open articles and information available to everyone — no account required.',
    href: `${base}encyclopedia/`,
  },
  {
    icon: '🛡️',
    title: 'Secure by Design',
    description:
      'Credentials are hashed client-side with SHA-256. Content encrypted with AES-256-GCM. No server required.',
    href: null,
  },
];

const sections = [
  {
    title: 'Encyclopedia',
    href: `${base}encyclopedia/`,
    description: 'Authoritative reference articles on specific topics',
    icon: '📖',
  },
  {
    title: 'Courses',
    href: `${base}courses/`,
    description: 'Structured learning paths with ordered lessons',
    icon: '🎓',
  },
  {
    title: 'Notes',
    href: `${base}notes/`,
    description: 'Quick references and personal notes',
    icon: '📝',
  },
  {
    title: 'Presentations',
    href: `${base}presentations/`,
    description: 'Web-based slide presentations',
    icon: '📊',
  },
  {
    title: 'Quizzes',
    href: `${base}quizzes/`,
    description: 'Assessments to test your knowledge',
    icon: '✅',
  },
  {
    title: 'Glossary',
    href: `${base}glossary/`,
    description: 'Keyword and keyphrase definitions',
    icon: '🔑',
  },
];
---

<BaseLayout
  title="Home"
  description="Root — a static knowledge hub with public and private content."
>
  <!-- Hero -->
  <section class="text-center py-16 px-4">
    <!-- Lightning bolt icon -->
    <div class="flex justify-center mb-6">
      <svg
        width="56"
        height="56"
        viewBox="0 0 24 24"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <defs>
          <linearGradient
            id="hero-bolt"
            x1="12"
            y1="2"
            x2="12"
            y2="22"
            gradientUnits="userSpaceOnUse"
          >
            <stop offset="0%" stop-color="#f97316"></stop>
            <stop offset="100%" stop-color="#f59e0b"></stop>
          </linearGradient>
        </defs>
        <path
          d="M13 2L4.09 12.96A1 1 0 005 14.5h6.5l-1 7.5 9.41-11.96A1 1 0 0019 8.5h-6.5L13 2z"
          fill="url(#hero-bolt)"></path>
      </svg>
    </div>

    <h1 class="text-5xl font-extrabold tracking-tight mb-5" style="color:#1a1a2e;">
      Welcome to Root
    </h1>

    <p class="text-lg text-base-content/70 max-w-2xl mx-auto mb-3 leading-relaxed">
      A public knowledge hub with courses, encyclopedias, notes, presentations, quizzes, and more —
      freely available to everyone.
    </p>

    <p class="text-sm text-base-content/40 mb-10">
      100% static, hosted on GitHub Pages. No backend. No passwords transmitted.
    </p>

    <!-- CTA buttons -->
    <div class="flex flex-wrap justify-center gap-4">
      <a
        href={`${base}encyclopedia/`}
        class="inline-flex items-center gap-2 px-7 py-3 rounded-xl bg-indigo-600 text-white font-semibold text-base hover:bg-indigo-700 transition-colors shadow-md"
      >
        Browse Public Content
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>

  <!-- Feature cards -->
  <section class="grid grid-cols-1 sm:grid-cols-2 gap-5 mt-4 px-4 pb-16 max-w-2xl mx-auto w-full">
    {
      features.map((f) => (
        <div class="feature-card bg-white rounded-2xl p-6 border border-base-300">
          <div class="text-3xl mb-4">{f.icon}</div>
          <h2 class="text-base font-bold mb-2" style="color:#1a1a2e;">
            {f.title}
          </h2>
          <p class="text-sm text-base-content/60 leading-relaxed">{f.description}</p>
        </div>
      ))
    }
  </section>

  <!-- Content sections grid -->
  <section class="px-4 pb-16">
    <h2 class="text-xl font-bold mb-5" style="color:#1a1a2e;">Explore Content</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {
        sections.map((section) => (
          <a
            href={section.href}
            class="feature-card card bg-white border border-base-300 hover:shadow-md transition-shadow no-underline rounded-xl"
          >
            <div class="card-body py-5 px-5">
              <span class="text-2xl">{section.icon}</span>
              <h3 class="card-title text-sm font-semibold mt-2" style="color:#1a1a2e;">
                {section.title}
              </h3>
              <p class="text-xs text-base-content/60">{section.description}</p>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
