---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import DrugBrowser from '../../components/pharmacology/DrugBrowser.svelte';
import classDescriptionsRaw from '../../data/drug-class-descriptions.json';

const entries = await getCollection('pharmacology', ({ data }) => !data.draft);
entries.sort((a, b) => a.data.title.localeCompare(b.data.title));

const base = import.meta.env.BASE_URL;

const drugs = entries.map((e) => ({
  slug: e.slug,
  title: e.data.title,
  genericName: e.data.genericName,
  brandNames: e.data.brandNames,
  drugClass: e.data.drugClass,
  tags: e.data.tags,
}));

const classDescriptions = classDescriptionsRaw as Record<string, string>;
---

<BaseLayout
  title="💊 Pharmacology"
  description="Browse 200+ NCLEX-focused drug entries with nursing considerations, side effects, and patient teaching."
>
  <h1 class="text-3xl font-extrabold mb-2" style="color:#1a1a2e;">💊 Pharmacology</h1>
  <p class="text-base-content/60 mb-6">
    Browse {entries.length} drug entries — search by name, class, or tag.
  </p>

  <script define:vars={{ base }}>
    window.__ASTRO_BASE__ = base;
  </script>

  <DrugBrowser drugs={drugs} classDescriptions={classDescriptions} client:load />
</BaseLayout>
