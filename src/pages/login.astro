---
import '../styles/global.css';

// AUTH_HASH is a SHA-256 hex digest of "username:password".
// It is injected at build time from the AUTH_HASH GitHub repository secret.
// See .env.example for instructions on generating a valid hash.
const authHash = import.meta.env.AUTH_HASH ?? '';
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en" data-theme="corporate">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Sign in to access Garden" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>Sign In | Garden</title>
  </head>
  <body class="min-h-screen flex items-center justify-center" style="background-color:#f5f5f7;">
    <div class="card bg-white shadow-md w-full max-w-sm mx-4">
      <div class="card-body gap-5">
        <!-- Logo / brand -->
        <div class="flex items-center gap-2 justify-center">
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <defs>
              <linearGradient
                id="login-leaf"
                x1="4"
                y1="2"
                x2="20"
                y2="22"
                gradientUnits="userSpaceOnUse"
              >
                <stop offset="0%" stop-color="#22c55e"></stop>
                <stop offset="100%" stop-color="#16a34a"></stop>
              </linearGradient>
            </defs>
            <path
              d="M17 8C8 10 5.9 16.17 3.82 21.34L5.71 22l1-2.3A4.49 4.49 0 008 20C19 20 22 3 22 3c-1 2-8 7-13 7"
              fill="url(#login-leaf)"></path>
          </svg>
          <span class="font-bold text-xl tracking-tight text-base-content">Garden</span>
        </div>

        <div class="text-center">
          <h1 class="text-2xl font-bold text-base-content">Sign In</h1>
          <p class="text-gray-500 text-sm mt-1 font-sans">
            Enter your credentials to access the site.
          </p>
        </div>

        <form id="login-form" class="flex flex-col gap-4 font-sans">
          <label class="form-control">
            <div class="label">
              <span class="label-text text-base-content font-medium">Username</span>
            </div>
            <input
              type="text"
              id="username"
              autocomplete="username"
              class="input input-bordered w-full"
              placeholder="Username"
              required
            />
          </label>

          <label class="form-control">
            <div class="label">
              <span class="label-text text-base-content font-medium">Password</span>
            </div>
            <input
              type="password"
              id="password"
              autocomplete="current-password"
              class="input input-bordered w-full"
              placeholder="Password"
              required
            />
          </label>

          <button type="submit" class="btn btn-primary w-full">Sign In</button>

          <p id="auth-error" hidden class="text-error text-sm text-center">
            Incorrect username or password. Please try again.
          </p>
        </form>
      </div>
    </div>
  </body>
</html>

<script define:vars={{ authHash, base }}>
  const SESSION_KEY = 'lms_auth';
  const REDIRECT_KEY = 'lms_redirect';

  // If already authenticated, send to intended destination or home.
  if (sessionStorage.getItem(SESSION_KEY) === 'ok') {
    const dest = sessionStorage.getItem(REDIRECT_KEY) || base;
    sessionStorage.removeItem(REDIRECT_KEY);
    window.location.replace(dest);
  }

  document.getElementById('login-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const usernameEl = /** @type {HTMLInputElement|null} */ (document.getElementById('username'));
    const passwordEl = /** @type {HTMLInputElement|null} */ (document.getElementById('password'));
    const errorEl = document.getElementById('auth-error');

    const username = usernameEl?.value?.trim() ?? '';
    const password = passwordEl?.value ?? '';

    // Hash "username:password" with SHA-256 and compare to the embedded AUTH_HASH.
    const text = `${username}:${password}`;
    const encoded = new TextEncoder().encode(text);
    const hashBuffer = await crypto.subtle.digest('SHA-256', encoded);
    const hashHex = Array.from(new Uint8Array(hashBuffer))
      .map((b) => b.toString(16).padStart(2, '0'))
      .join('');

    if (authHash && hashHex === authHash) {
      sessionStorage.setItem(SESSION_KEY, 'ok');
      const dest = sessionStorage.getItem(REDIRECT_KEY) || base;
      sessionStorage.removeItem(REDIRECT_KEY);
      window.location.replace(dest);
    } else {
      if (errorEl) errorEl.hidden = false;
    }
  });
</script>
