---
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import ContentLayout from '../../layouts/ContentLayout.astro';
import { getRelatedContent } from '../../utils/related';
import type { RelatedItem } from '../../utils/related';
import { getReadingTime } from '../../utils/readingTime';

export const getStaticPaths: GetStaticPaths = async () => {
  const base = import.meta.env.BASE_URL;
  const [entries, allEncyclopedia, allCourses] = await Promise.all([
    getCollection(
      'notes',
      ({ data }) => !data.draft && data.visibility === 'public' && data.reviewState === 'published'
    ),
    getCollection('encyclopedia', ({ data }) => !data.draft),
    getCollection('courses', ({ data }) => !data.draft),
  ]);

  return entries.map((entry) => {
    const currentTags = entry.data.tags ?? [];
    return {
      params: { slug: entry.slug },
      props: {
        entry,
        relatedEncyclopedia: getRelatedContent(
          entry.slug,
          currentTags,
          allEncyclopedia,
          (slug) => `${base}encyclopedia/${slug}/`
        ),
        relatedCourses: getRelatedContent(
          entry.slug,
          currentTags,
          allCourses,
          (slug) => `${base}courses/${slug}/`
        ),
        relatedNotes: getRelatedContent(
          entry.slug,
          currentTags,
          entries,
          (slug) => `${base}notes/${slug}/`
        ),
      },
    };
  });
};

const {
  entry,
  relatedEncyclopedia,
  relatedCourses,
  relatedNotes,
}: {
  entry: Awaited<ReturnType<typeof getCollection<'notes'>>>[number];
  relatedEncyclopedia: RelatedItem[];
  relatedCourses: RelatedItem[];
  relatedNotes: RelatedItem[];
} = Astro.props;
const { Content } = await entry.render();
const readingTime = getReadingTime(entry.body);

const base = import.meta.env.BASE_URL;
const { reviewReason, duplicateOf, sourceIssue, sourceUrl, relatedLinks } = entry.data;
---

<ContentLayout
  title={entry.data.title}
  publishedAt={entry.data.createdAt}
  updatedAt={entry.data.updatedAt}
  tags={entry.data.tags}
  collection="notes"
  backLabel="Notes"
  backHref={`${base}notes/`}
  relatedEncyclopedia={relatedEncyclopedia}
  relatedCourses={relatedCourses}
  relatedNotes={relatedNotes}
  readingTime={readingTime}
>
  {
    duplicateOf && (
      <div class="alert alert-warning mb-6 font-sans" role="alert">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5 shrink-0"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"
          />
        </svg>
        <div>
          <p class="font-semibold">Possible duplicate detected.</p>
          <p class="text-sm mt-1">
            This note may overlap with{' '}
            <a href={`${base}notes/${duplicateOf}/`} class="underline font-medium">
              {duplicateOf}
            </a>
            . Consider merging or reviewing both.
          </p>
          {reviewReason && <p class="text-sm mt-1">{reviewReason}</p>}
        </div>
      </div>
    )
  }

  <Content />

  {
    (sourceIssue || sourceUrl || relatedLinks.length > 0) && (
      <aside class="mt-10 pt-6 border-t border-base-300 font-sans text-sm text-base-content/70 space-y-3">
        <p class="font-semibold uppercase tracking-wide text-xs text-base-content/50">
          Provenance &amp; Related Links
        </p>
        {sourceIssue && (
          <p>
            <span class="font-semibold">Source issue:</span>{' '}
            <a
              href={sourceIssue}
              class="underline hover:text-base-content/90 transition-colors"
              target="_blank"
              rel="noopener"
            >
              {sourceIssue}
            </a>
          </p>
        )}
        {sourceUrl && (
          <p>
            <span class="font-semibold">Source:</span>{' '}
            <a
              href={sourceUrl}
              class="underline hover:text-base-content/90 transition-colors"
              target="_blank"
              rel="noopener"
            >
              {sourceUrl}
            </a>
          </p>
        )}
        {relatedLinks.length > 0 && (
          <div>
            <p class="font-semibold mb-1">Related links:</p>
            <ul class="list-disc list-inside space-y-1">
              {relatedLinks.map((link) => (
                <li>
                  <a
                    href={link.url}
                    class="underline hover:text-base-content/90 transition-colors"
                    target={link.url.startsWith('http') ? '_blank' : undefined}
                    rel={link.url.startsWith('http') ? 'noopener' : undefined}
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </aside>
    )
  }
</ContentLayout>
