---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const entries = await getCollection('notes', ({ data }) => !data.draft);
entries.sort((a, b) => b.data.createdAt.getTime() - a.data.createdAt.getTime());

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Notes" description="Quick personal notes and references">
  <h1>Notes</h1>
  <p>Quick references and personal notes.</p>

  {
    entries.length === 0 ? (
      <p>
        No notes yet. Add Markdown files to <code>src/content/notes/</code>.
      </p>
    ) : (
      <ul class="entry-list">
        {entries.map((entry) => (
          <li>
            <a href={`${base}notes/${entry.slug}/`}>
              <strong>{entry.data.title}</strong>
            </a>
            <time datetime={entry.data.createdAt.toISOString()}>
              {entry.data.createdAt.toLocaleDateString()}
            </time>
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>
