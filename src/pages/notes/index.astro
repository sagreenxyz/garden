---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const entries = await getCollection(
  'notes',
  ({ data }) => !data.draft && data.visibility === 'public' && data.reviewState === 'published'
);
entries.sort((a, b) => b.data.createdAt.getTime() - a.data.createdAt.getTime());

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Notes" description="Quick personal notes and references">
  <h1 class="text-3xl font-bold mb-2">Notes</h1>
  <p class="text-base-content/60 font-sans mb-6">Quick references and personal notes.</p>

  {
    entries.length === 0 ? (
      <div class="alert font-sans">
        <span>
          No notes yet. Add <code>.mdx</code> files to <code>src/content/notes/</code>.
        </span>
      </div>
    ) : (
      <ul class="space-y-4">
        {entries.map((entry) => (
          <li>
            <a
              href={`${base}notes/${entry.slug}/`}
              class="card card-border bg-base-100 hover:shadow-md transition-shadow no-underline font-sans block"
            >
              <div class="card-body py-4">
                <div class="flex items-start justify-between gap-2 flex-wrap">
                  <h2 class="card-title text-base">{entry.data.title}</h2>
                  <div class="flex gap-1 flex-wrap">
                    {entry.data.duplicateOf && (
                      <span class="badge badge-error badge-sm font-sans">possible duplicate</span>
                    )}
                    {entry.data.noteType !== 'general' && (
                      <span class="badge badge-ghost badge-sm font-sans">
                        {entry.data.noteType}
                      </span>
                    )}
                  </div>
                </div>
                <time
                  datetime={entry.data.createdAt.toISOString()}
                  class="text-xs text-base-content/40 mt-1"
                >
                  {entry.data.createdAt.toLocaleDateString()}
                </time>
                {entry.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1 mt-2">
                    {entry.data.tags.map((tag) => (
                      <span class="badge badge-outline badge-sm">{tag}</span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          </li>
        ))}
      </ul>
    )
  }
</BaseLayout>
