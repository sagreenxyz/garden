---
import BaseLayout from './BaseLayout.astro';
import ContentMeta from '../components/common/ContentMeta.astro';
import type { CurriculumAlignment } from '../types/nursing';

export interface Props {
  title: string;
  description?: string;
  publishedAt?: Date;
  updatedAt?: Date;
  tags?: string[];
  collection?: string;
  /** Optional BSN nursing curriculum alignment metadata */
  curriculum?: CurriculumAlignment;
  /** Back link label and href */
  backLabel?: string;
  backHref?: string;
  /** Estimated reading time in minutes */
  readingTime?: number;
  /** Difficulty level (from courses schema) */
  level?: 'beginner' | 'intermediate' | 'advanced';
}

const {
  title,
  description,
  publishedAt,
  updatedAt,
  tags = [],
  collection,
  curriculum,
  backLabel,
  backHref,
  readingTime,
  level,
} = Astro.props;

const base = import.meta.env.BASE_URL;
---

<BaseLayout title={title} description={description} fullWidth={true}>
  <!-- Breadcrumb -->
  {
    (backHref || collection) && (
      <nav class="px-6 py-3 text-sm text-base-content/50 border-b border-base-300 bg-white">
        <ol class="flex items-center gap-1.5 flex-wrap max-w-6xl mx-auto">
          <li>
            <a href={base} class="hover:text-indigo-600 transition-colors">
              Home
            </a>
          </li>
          {collection && (
            <>
              <li aria-hidden="true" class="text-base-content/30">
                ›
              </li>
              <li>
                <a
                  href={`${base}${collection}/`}
                  class="capitalize hover:text-indigo-600 transition-colors"
                >
                  {collection}
                </a>
              </li>
            </>
          )}
          <li aria-hidden="true" class="text-base-content/30">
            ›
          </li>
          <li class="text-base-content/70 truncate max-w-xs">{title}</li>
        </ol>
      </nav>
    )
  }

  <!-- Three-column article grid -->
  <div class="article-grid max-w-6xl mx-auto px-4 py-8">
    <!-- Left sidebar: curriculum alignment -->
    <aside class="article-sidebar-left space-y-4">
      {
        curriculum && (
          <div class="bg-white rounded-xl border border-base-300 p-4 text-sm">
            <p class="text-xs font-bold uppercase tracking-widest text-indigo-600 mb-3">
              Nursing Relevance
            </p>
            {curriculum.learningObjectives.length > 0 && (
              <ul class="space-y-1.5">
                {curriculum.learningObjectives.map((obj) => (
                  <li class="flex gap-2 text-xs text-base-content/70 leading-snug">
                    <span class="text-green-500 mt-0.5 shrink-0">✓</span>
                    {obj}
                  </li>
                ))}
              </ul>
            )}
            {curriculum.aacnEssentials.length > 0 && (
              <div class="mt-3 pt-3 border-t border-base-200">
                <p class="text-xs font-semibold text-base-content/50 mb-1">AACN Essentials</p>
                <div class="flex flex-wrap gap-1">
                  {curriculum.aacnEssentials.map((d) => (
                    <span class="badge badge-outline badge-xs">{d}</span>
                  ))}
                </div>
              </div>
            )}
            {curriculum.qsenCompetencies.length > 0 && (
              <div class="mt-3 pt-3 border-t border-base-200">
                <p class="text-xs font-semibold text-base-content/50 mb-1">QSEN</p>
                <div class="flex flex-wrap gap-1">
                  {curriculum.qsenCompetencies.map((q) => (
                    <span class="badge badge-outline badge-xs">{q}</span>
                  ))}
                </div>
              </div>
            )}
          </div>
        )
      }

      <!-- Back link -->
      {
        (backHref || collection) && (
          <a
            href={backHref ?? `${base}${collection}/`}
            class="flex items-center gap-1.5 text-sm text-base-content/60 hover:text-indigo-600 transition-colors bg-white rounded-xl border border-base-300 p-3"
          >
            <span aria-hidden="true">←</span>
            {backLabel ?? `Back to ${collection}`}
          </a>
        )
      }
    </aside>

    <!-- Main article content -->
    <article>
      <!-- Article header -->
      <header class="mb-6 pb-5 border-b border-base-300">
        <h1 class="text-3xl font-extrabold mb-2" style="color:#1a1a2e;">{title}</h1>
        {
          description && (
            <p class="text-base-content/65 mt-1 text-base leading-relaxed">{description}</p>
          )
        }
        <ContentMeta
          readingTime={readingTime}
          level={level}
          publishedAt={publishedAt}
          updatedAt={updatedAt}
          tags={tags}
        />
      </header>

      <div class="prose prose-lms max-w-none font-prose">
        <slot />
      </div>
    </article>

    <!-- Right sidebar: Table of Contents (client-side populated) -->
    <aside class="article-sidebar-right">
      <div class="bg-white rounded-xl border border-base-300 p-4" id="toc-container">
        <p class="text-xs font-bold uppercase tracking-widest text-base-content/40 mb-3">
          Contents
        </p>
        <ol class="toc-list" id="toc-list">
          <!-- Populated by client script -->
        </ol>
      </div>
    </aside>
  </div>
</BaseLayout>

<script>
  // ── Pagination: split prose content into pages by H2 ─────────────────────
  const proseEl = document.querySelector('.prose-lms');
  /** @type {HTMLElement[]} */
  const pageDivs = [];

  if (proseEl) {
    const children = Array.from(proseEl.children);
    const h2Count = children.filter((el) => el.tagName === 'H2').length;

    if (h2Count > 1) {
      /** @type {Element[]} */
      let pageElements = [];
      let inPagination = false;

      for (const el of children) {
        if (el.tagName === 'H2') {
          if (inPagination) {
            const pageDiv = document.createElement('div');
            pageDiv.className = 'content-page';
            pageDiv.hidden = pageDivs.length > 0;
            proseEl.insertBefore(pageDiv, pageElements[0]);
            pageElements.forEach((e) => pageDiv.appendChild(e));
            pageDivs.push(pageDiv);
          }
          inPagination = true;
          pageElements = [el];
        } else if (inPagination) {
          pageElements.push(el);
        }
        // elements before the first H2 stay in place (always visible)
      }

      // Wrap the last section
      if (pageElements.length > 0) {
        const pageDiv = document.createElement('div');
        pageDiv.className = 'content-page';
        pageDiv.hidden = pageDivs.length > 0;
        proseEl.insertBefore(pageDiv, pageElements[0]);
        pageElements.forEach((e) => pageDiv.appendChild(e));
        pageDivs.push(pageDiv);
      }
    }
  }

  // ── Pagination state & navigation ────────────────────────────────────────
  let currentPage = 0;

  function goToPage(index) {
    if (index < 0 || index >= pageDivs.length) return;
    pageDivs[currentPage].hidden = true;
    currentPage = index;
    pageDivs[currentPage].hidden = false;
    const prevBtn = /** @type {HTMLButtonElement|null} */ (document.getElementById('page-prev'));
    const nextBtn = /** @type {HTMLButtonElement|null} */ (document.getElementById('page-next'));
    const counter = document.getElementById('page-counter');
    if (prevBtn) prevBtn.disabled = currentPage === 0;
    if (nextBtn) nextBtn.disabled = currentPage === pageDivs.length - 1;
    if (counter) counter.textContent = `Page ${currentPage + 1} of ${pageDivs.length}`;
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  // ── TOC: hierarchical numbering ───────────────────────────────────────────
  const article = document.querySelector('article');
  const tocList = document.getElementById('toc-list');
  const tocContainer = document.getElementById('toc-container');

  if (article && tocList) {
    const headings = article.querySelectorAll('h2, h3');
    if (headings.length === 0 && tocContainer) {
      tocContainer.hidden = true;
    } else {
      let h2Num = 0;
      let h3Num = 0;

      headings.forEach((h, i) => {
        if (!h.id) h.id = `heading-${i}`;
        const li = document.createElement('li');
        let label;

        if (h.tagName === 'H2') {
          h2Num++;
          h3Num = 0;
          li.style.paddingLeft = '0';
          label = `${h2Num}. ${(h.textContent || '').trim()}`;
        } else {
          h3Num++;
          li.style.paddingLeft = '0.75rem';
          label = `${h2Num}.${h3Num} ${(h.textContent || '').trim()}`;
        }

        const a = document.createElement('a');
        a.href = `#${h.id}`;
        a.textContent = label;

        // When paginated, clicking a TOC link shows the right page then scrolls
        if (pageDivs.length > 1) {
          a.addEventListener('click', (e) => {
            e.preventDefault();
            const pageIndex = pageDivs.findIndex((pd) => pd.contains(h));
            if (pageIndex !== -1) goToPage(pageIndex);
            setTimeout(() => h.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50);
          });
        }

        li.appendChild(a);
        tocList.appendChild(li);
      });
    }
  }

  // ── Pagination nav UI ─────────────────────────────────────────────────────
  if (pageDivs.length > 1 && proseEl) {
    const nav = document.createElement('div');
    nav.className = 'content-page-nav';
    nav.innerHTML = `
      <button id="page-prev" class="btn btn-sm btn-ghost gap-2 font-sans" disabled>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
        Previous
      </button>
      <span id="page-counter">Page 1 of ${pageDivs.length}</span>
      <button id="page-next" class="btn btn-sm btn-outline btn-primary gap-2 font-sans">
        Next
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      </button>
    `;
    proseEl.after(nav);

    const prevBtn = document.getElementById('page-prev');
    const nextBtn = document.getElementById('page-next');
    if (prevBtn) prevBtn.addEventListener('click', () => goToPage(currentPage - 1));
    if (nextBtn) nextBtn.addEventListener('click', () => goToPage(currentPage + 1));
  }
</script>
