---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  fullWidth?: boolean;
}

const {
  title,
  description = 'Root — a static knowledge hub with public and private content.',
  fullWidth = false,
} = Astro.props;
const base = import.meta.env.BASE_URL;

const publicLinks = [
  { href: base, label: 'Home' },
  { href: `${base}encyclopedia/`, label: 'Encyclopedia' },
  { href: `${base}courses/`, label: 'Courses' },
  { href: `${base}notes/`, label: 'Notes' },
  { href: `${base}presentations/`, label: 'Presentations' },
  { href: `${base}quizzes/`, label: 'Quizzes' },
  { href: `${base}glossary/`, label: 'Glossary' },
];

const privateLink = { href: `${base}private/`, label: 'Private' };
---

<!doctype html>
<html lang="en" data-theme="corporate">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{title} | Root</title>
  </head>
  <body class="min-h-screen flex flex-col text-base-content" style="background-color:#f5f5f7;">
    <!-- Navbar -->
    <header class="navbar bg-white border-b border-base-300 px-4 shadow-sm">
      <!-- Brand -->
      <div class="navbar-start">
        <a
          href={base}
          class="flex items-center gap-1.5 font-bold text-lg tracking-tight text-base-content hover:opacity-80 transition-opacity"
          aria-label="Root home"
        >
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <defs>
              <linearGradient
                id="nav-bolt"
                x1="12"
                y1="2"
                x2="12"
                y2="22"
                gradientUnits="userSpaceOnUse"
              >
                <stop offset="0%" stop-color="#f97316"></stop>
                <stop offset="100%" stop-color="#f59e0b"></stop>
              </linearGradient>
            </defs>
            <path
              d="M13 2L4.09 12.96A1 1 0 005 14.5h6.5l-1 7.5 9.41-11.96A1 1 0 0019 8.5h-6.5L13 2z"
              fill="url(#nav-bolt)"></path>
          </svg>
          Root
        </a>
      </div>

      <!-- Desktop nav -->
      <nav class="navbar-center hidden lg:flex">
        <ul class="menu menu-horizontal px-1 gap-0.5">
          {
            publicLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm font-medium px-3 py-1.5 rounded-md hover:bg-base-200 transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
          <!-- Private link: shown only when authenticated -->
          <li id="nav-private-desktop" style="display:none">
            <a
              href={privateLink.href}
              class="text-sm font-medium px-3 py-1.5 rounded-md hover:bg-base-200 transition-colors"
            >
              🔒 {privateLink.label}
            </a>
          </li>
        </ul>
      </nav>

      <!-- Right side: auth controls + mobile hamburger -->
      <div class="navbar-end gap-2">
        <!-- Sign In link: visible when logged out -->
        <a
          id="nav-signin-desktop"
          href={`${base}login/`}
          class="btn btn-ghost btn-sm font-sans gap-2 hidden lg:inline-flex"
        >
          Sign In
        </a>
        <!-- Sign Out button: visible when logged in -->
        <button
          id="nav-signout-desktop"
          class="btn btn-ghost btn-sm font-sans gap-2 hidden lg:inline-flex"
          style="display:none"
        >
          Sign Out
        </button>

        <!-- Mobile hamburger -->
        <div class="dropdown dropdown-end lg:hidden">
          <div tabindex="0" role="button" class="btn btn-ghost btn-sm" aria-label="Open navigation">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
          </div>
          <ul
            tabindex="0"
            class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow bg-base-100 rounded-box w-52"
          >
            {
              publicLinks.map((link) => (
                <li>
                  <a href={link.href}>{link.label}</a>
                </li>
              ))
            }
            <!-- Private link in mobile menu: shown only when authenticated -->
            <li id="nav-private-mobile" style="display:none">
              <a href={privateLink.href}>🔒 {privateLink.label}</a>
            </li>
            <!-- Auth items in mobile menu -->
            <li id="nav-signin-mobile">
              <a href={`${base}login/`}>Sign In</a>
            </li>
            <li id="nav-signout-mobile" style="display:none">
              <button id="nav-signout-mobile-btn" class="w-full text-left">Sign Out</button>
            </li>
          </ul>
        </div>
      </div>
    </header>

    <!-- Main content -->
    <main class={`flex-1 w-full ${fullWidth ? '' : 'max-w-6xl mx-auto px-4 py-10'}`}>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-white border-t border-base-300 p-6 text-center text-sm text-base-content/50">
      <p>
        &copy; {new Date().getFullYear()} Root &mdash; Built with
        <a href="https://astro.build" class="underline hover:text-base-content/80 transition-colors"
          >Astro</a
        >
      </p>
    </footer>
  </body>
</html>

<script define:vars={{ base }}>
  const SESSION_KEY = 'lms_auth';

  function applyAuthState() {
    const loggedIn = sessionStorage.getItem(SESSION_KEY) === 'ok';

    // Desktop
    const signinDesktop = document.getElementById('nav-signin-desktop');
    const signoutDesktop = document.getElementById('nav-signout-desktop');
    const privateDesktop = document.getElementById('nav-private-desktop');

    // Mobile
    const signinMobile = document.getElementById('nav-signin-mobile');
    const signoutMobile = document.getElementById('nav-signout-mobile');
    const privateMobile = document.getElementById('nav-private-mobile');

    if (loggedIn) {
      if (signinDesktop) signinDesktop.style.display = 'none';
      if (signoutDesktop) signoutDesktop.style.display = '';
      if (privateDesktop) privateDesktop.style.display = '';

      if (signinMobile) signinMobile.style.display = 'none';
      if (signoutMobile) signoutMobile.style.display = '';
      if (privateMobile) privateMobile.style.display = '';
    } else {
      if (signinDesktop) signinDesktop.style.display = '';
      if (signoutDesktop) signoutDesktop.style.display = 'none';
      if (privateDesktop) privateDesktop.style.display = 'none';

      if (signinMobile) signinMobile.style.display = '';
      if (signoutMobile) signoutMobile.style.display = 'none';
      if (privateMobile) privateMobile.style.display = 'none';
    }
  }

  function handleSignOut() {
    sessionStorage.removeItem(SESSION_KEY);
    window.location.replace(base + 'login/');
  }

  applyAuthState();

  document.getElementById('nav-signout-desktop')?.addEventListener('click', handleSignOut);
  document.getElementById('nav-signout-mobile-btn')?.addEventListener('click', handleSignOut);
</script>
