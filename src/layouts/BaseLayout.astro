---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  fullWidth?: boolean;
}

const {
  title,
  description = 'Root — a static knowledge hub with public and private content.',
  fullWidth = false,
} = Astro.props;
const base = import.meta.env.BASE_URL;

const publicLinks = [
  { href: base, label: 'Home' },
  { href: `${base}encyclopedia/`, label: 'Encyclopedia' },
  { href: `${base}courses/`, label: 'Courses' },
  { href: `${base}notes/`, label: 'Notes' },
  { href: `${base}presentations/`, label: 'Presentations' },
  { href: `${base}quizzes/`, label: 'Quizzes' },
  { href: `${base}glossary/`, label: 'Glossary' },
];
---

<!doctype html>
<html lang="en" data-theme="corporate">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>{title} | Root</title>
  </head>
  <body class="min-h-screen flex flex-col text-base-content" style="background-color:#f5f5f7;">
    <!-- Navbar -->
    <header class="navbar bg-white border-b border-base-300 px-4 shadow-sm">
      <!-- Brand -->
      <div class="navbar-start">
        <a
          href={base}
          class="flex items-center gap-1.5 font-bold text-lg tracking-tight text-base-content hover:opacity-80 transition-opacity"
          aria-label="Root home"
        >
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <defs>
              <linearGradient
                id="nav-bolt"
                x1="12"
                y1="2"
                x2="12"
                y2="22"
                gradientUnits="userSpaceOnUse"
              >
                <stop offset="0%" stop-color="#f97316"></stop>
                <stop offset="100%" stop-color="#f59e0b"></stop>
              </linearGradient>
            </defs>
            <path
              d="M13 2L4.09 12.96A1 1 0 005 14.5h6.5l-1 7.5 9.41-11.96A1 1 0 0019 8.5h-6.5L13 2z"
              fill="url(#nav-bolt)"></path>
          </svg>
          Root
        </a>
      </div>

      <!-- Desktop nav -->
      <nav class="navbar-center hidden lg:flex">
        <ul class="menu menu-horizontal px-1 gap-0.5">
          {
            publicLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm font-medium px-3 py-1.5 rounded-md hover:bg-base-200 transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <!-- Right side: private area link + mobile hamburger -->
      <div class="navbar-end gap-2">
        <a
          href={`${base}private/`}
          class="hidden lg:inline-flex items-center gap-1.5 btn btn-sm btn-primary normal-case"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-3.5 w-3.5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
            <path d="M7 11V7a5 5 0 0110 0v4"></path>
          </svg>
          Private Area
        </a>

        <!-- Mobile hamburger -->
        <div class="dropdown dropdown-end lg:hidden">
          <div tabindex="0" role="button" class="btn btn-ghost btn-sm" aria-label="Open navigation">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
          </div>
          <ul
            tabindex="0"
            class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow bg-base-100 rounded-box w-52"
          >
            {
              publicLinks.map((link) => (
                <li>
                  <a href={link.href}>{link.label}</a>
                </li>
              ))
            }
            <li class="mt-2 pt-2 border-t border-base-300">
              <a href={`${base}private/`} class="font-medium text-primary">Private Area</a>
            </li>
          </ul>
        </div>
      </div>
    </header>

    <!-- Main content -->
    <main class={`flex-1 w-full ${fullWidth ? '' : 'max-w-6xl mx-auto px-4 py-10'}`}>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-white border-t border-base-300 p-6 text-center text-sm text-base-content/50">
      <p>
        &copy; {new Date().getFullYear()} Root &mdash; Built with
        <a href="https://astro.build" class="underline hover:text-base-content/80 transition-colors"
          >Astro</a
        >
      </p>
    </footer>
  </body>
</html>
