---
export interface Props {
  title?: string;
  number?: number;
}

const { title, number } = Astro.props;
---

<section class="card card-border bg-base-100 p-6 min-h-48">
  {
    (number !== undefined || title) && (
      <div class="mb-4 border-b border-base-300 pb-3">
        {number !== undefined && (
          <span class="text-xs font-sans text-base-content/40 uppercase tracking-widest">
            Slide {number}
          </span>
        )}
        {title && <h2 class="text-xl font-semibold mt-1">{title}</h2>}
      </div>
    )
  }
  <div class="prose prose-lms max-w-none">
    <slot />
  </div>
</section>
