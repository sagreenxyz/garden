---
import type { RelatedItem } from '../../utils/related';

export interface Props {
  relatedEncyclopedia?: RelatedItem[];
  relatedCourses?: RelatedItem[];
  relatedNotes?: RelatedItem[];
}

const { relatedEncyclopedia = [], relatedCourses = [], relatedNotes = [] } = Astro.props;

const hasAny =
  relatedEncyclopedia.length > 0 || relatedCourses.length > 0 || relatedNotes.length > 0;
---

{
  hasAny && (
    <section class="mt-10 pt-6 border-t border-base-300 font-sans">
      <p class="text-xs font-bold uppercase tracking-widest text-base-content/40 mb-4">
        Related Content
      </p>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {relatedEncyclopedia.length > 0 && (
          <div>
            <p class="text-xs font-semibold text-indigo-600 uppercase tracking-wide mb-2">
              Encyclopedia
            </p>
            <ul class="space-y-1.5">
              {relatedEncyclopedia.map((item) => (
                <li>
                  <a
                    href={item.url}
                    class="text-sm text-base-content/80 hover:text-indigo-600 transition-colors underline-offset-2 hover:underline"
                  >
                    {item.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
        {relatedCourses.length > 0 && (
          <div>
            <p class="text-xs font-semibold text-indigo-600 uppercase tracking-wide mb-2">
              Courses
            </p>
            <ul class="space-y-1.5">
              {relatedCourses.map((item) => (
                <li>
                  <a
                    href={item.url}
                    class="text-sm text-base-content/80 hover:text-indigo-600 transition-colors underline-offset-2 hover:underline"
                  >
                    {item.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
        {relatedNotes.length > 0 && (
          <div>
            <p class="text-xs font-semibold text-indigo-600 uppercase tracking-wide mb-2">Notes</p>
            <ul class="space-y-1.5">
              {relatedNotes.map((item) => (
                <li>
                  <a
                    href={item.url}
                    class="text-sm text-base-content/80 hover:text-indigo-600 transition-colors underline-offset-2 hover:underline"
                  >
                    {item.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </section>
  )
}
